# .env — compose-level configuration.
#
# Copy to `.env` in the project root. Docker Compose auto-loads this file
# for ${VAR} interpolation. The values here are used in TWO places:
#   1. Inline in docker-compose.yml (e.g. Traefik labels, db service env).
#   2. As substitution source for the env_file values in `.env.wordpress`
#      — Compose interpolates ${...} inside env_file contents using the
#      project-level .env (compose-spec: unquoted/double-quoted values
#      in env_file support interpolation).
#
# So define every shared value HERE once; .env.wordpress just references
# them. Never commit the filled-in .env — add it to the project .gitignore.

# Compose project name. Prefix for container, volume, and network names.
# Pick something unique per host (e.g. the site slug).
COMPOSE_PROJECT_NAME=my-site

# Public domain — referenced by the Traefik Host(`...`) router rule
# in compose.example.yml.
WP_DOMAIN=example.com

# ---- Database credentials ----
# Consumed by the db service (inline `environment:` in compose.example.yml)
# AND referenced from .env.wordpress as ${MYSQL_*} so WP sees identical creds.
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=change_me

# Port the WP container uses to connect to db (also the port mariadb
# listens on inside its container — default 3306).
DB_PORT=3306
