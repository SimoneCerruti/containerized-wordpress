# .env.wordpress — runtime environment for the WordPress container.
#
# Copy to `.env.wordpress` in the project root. Passed into the wp
# container via `env_file:` in compose.base.yml. Visible to PHP, cron
# jobs, and wp-cli.
#
# IMPORTANT — ${VAR} references below are interpolated by Compose using
# values from the project-level .env file BEFORE the file is handed to
# the container. So MYSQL_* must be defined in .env (see .env.example).
# Single-quoted values would be passed literally — keep them unquoted or
# double-quoted to enable interpolation.
#
# NEVER commit the filled-in version. Add `.env.wordpress` to the
# project's .gitignore.

# ---- Database connection ----
# Resolved from .env via Compose interpolation, so WP credentials always
# match what the db service is created with — no duplication.
WORDPRESS_DB_HOST=db:${DB_PORT}
WORDPRESS_DB_NAME=${MYSQL_DATABASE}
WORDPRESS_DB_USER=${MYSQL_USER}
WORDPRESS_DB_PASSWORD=${MYSQL_PASSWORD}
WORDPRESS_TABLE_PREFIX=wp_

# ---- WordPress secret keys / salts ----
# Generate fresh values for every site:
#   curl https://api.wordpress.org/secret-key/1.1/salt/
WORDPRESS_AUTH_KEY=
WORDPRESS_SECURE_AUTH_KEY=
WORDPRESS_LOGGED_IN_KEY=
WORDPRESS_NONCE_KEY=
WORDPRESS_AUTH_SALT=
WORDPRESS_SECURE_AUTH_SALT=
WORDPRESS_LOGGED_IN_SALT=
WORDPRESS_NONCE_SALT=

# ---- wp-config.php extras (production defaults) ----
# Multi-line double-quoted value — supported by compose-spec env_file.
# These get injected verbatim into wp-config.php by the WP entrypoint.
#
# Policy choices baked in here:
#   - WP_DEBUG_LOG=true, WP_DEBUG_DISPLAY=false → silent error logging
#     to wp-content/debug.log, no errors leaked to visitors.
#   - WP_AUTO_UPDATE_CORE=false → core never auto-updates (managed via
#     deploy / base version bumps).
#   - AUTOMATIC_UPDATER_DISABLED=false → plugins/themes/translations
#     CAN still auto-update (security patches without manual deploy).
#   - DISABLE_WP_CRON=true → WP's pseudo-cron is off; the container's
#     real cron triggers wp-cron.sh via HTTP loopback for reliability.
#   - WP_MEMORY_LIMIT / WP_MAX_MEMORY_LIMIT = 512M for frontend and admin.
#   - FORCE_SSL_ADMIN=true → /wp-admin only over HTTPS (assumes Traefik
#     terminates TLS in front).
WORDPRESS_CONFIG_EXTRA="
    define('WP_DEBUG_LOG', true);
    define('WP_DEBUG_DISPLAY', false);
    @ini_set('display_errors', 0);
    define('WP_AUTO_UPDATE_CORE', false);
    define('AUTOMATIC_UPDATER_DISABLED', false);
    define('DISABLE_WP_CRON', true);
    define('WP_MEMORY_LIMIT', '512M');
    define('WP_MAX_MEMORY_LIMIT', '512M');
    define('FORCE_SSL_ADMIN', true);"

# ---- Malware scan (used by wp-malware-scan.sh) ----
# All scan-specific vars are prefixed MALWARE_SCAN_.
# Recipient for the nightly scan report. The scan still runs if empty
# but no email is sent (error logged to /var/log/wp_app/wp-malware-scan.log).
MALWARE_SCAN_NOTIFY_EMAIL=security@example.com

# Optional malware-scan tuning (defaults shown):
# MALWARE_SCAN_PATH_EXCLUDES=/etc/wp-malware-scan/path-excludes.txt
# MALWARE_SCAN_WHITELIST=/var/lib/wp-malware-scan/whitelist.sha256
# MALWARE_SCAN_STATE_DIR=/var/lib/wp-malware-scan
# MALWARE_SCAN_ADMIN_DAYS=30
# MALWARE_SCAN_LOG_FILE=/var/log/wp_app/wp-malware-scan.log

# ---- WP install path (referenced by cron + scan scripts) ----
# Default /var/www/html matches the official WordPress image; only change
# if you've moved the install inside the container.
WP_PATH=/var/www/html
